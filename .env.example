# =============================================================================
# AI Box - Configuration globale
# =============================================================================
# Ce fichier est généré automatiquement par ./install.sh
# Ne pas committer (.env est dans .gitignore)
# =============================================================================

# ----- IDENTITÉ CLIENT -----
CLIENT_NAME=Acme SARL
CLIENT_SECTOR=services        # services|btp|juridique|sante|immobilier|comptabilite|autre
CLIENT_USERS_COUNT=15

# ----- DOMAINE & TLS -----
# Domaine racine — les sous-domaines seront auto.<DOMAIN>, chat.<DOMAIN>, etc.
DOMAIN=ai.acme.local
ADMIN_EMAIL=admin@acme.fr

# ----- ADMIN PAR DÉFAUT (Authentik) -----
ADMIN_USERNAME=akadmin
ADMIN_PASSWORD=                # Généré aléatoirement par install.sh

# ----- HARDWARE PROFILE -----
HW_PROFILE=tpe                 # tpe|pme|pme-plus
GPU_VRAM_GB=12

# ----- MODÈLES OLLAMA -----
LLM_MAIN=qwen2.5:7b
LLM_EMBED=bge-m3
LLM_CODE=                      # qwen2.5-coder:7b si activé

# ----- TECHNOS DU CLIENT (pour activer les bons connecteurs) -----
# Mettre à 'true' pour activer le template/connecteur correspondant
CLIENT_HAS_M365=false          # Microsoft 365 / Exchange / SharePoint / OneDrive
CLIENT_HAS_GOOGLE=false        # Google Workspace (Gmail, Drive, Calendar)
CLIENT_HAS_AD=false            # Active Directory / Azure AD
CLIENT_HAS_ODOO=false
CLIENT_HAS_SAGE=false
CLIENT_HAS_SALESFORCE=false
CLIENT_HAS_HUBSPOT=false
CLIENT_HAS_PG=false            # Base PostgreSQL métier
CLIENT_HAS_MYSQL=false
CLIENT_HAS_MSSQL=false
CLIENT_HAS_GLPI=false
CLIENT_HAS_NEXTCLOUD=false
CLIENT_HAS_SMB=false           # Partage de fichiers SMB/CIFS

# ----- SECRETS GÉNÉRÉS (jamais à modifier manuellement) -----
# Tous ces secrets sont créés aléatoirement par install.sh.
PG_DIFY_PASSWORD=
PG_AUTHENTIK_PASSWORD=
AUTHENTIK_SECRET_KEY=
DIFY_SECRET_KEY=
QDRANT_API_KEY=                 # bind 127.0.0.1 + clé pour accès interne
AGENTS_API_KEY=                 # service agents-autonomous (Bearer)
MEM0_API_KEY=                   # service memory mem0-style (Bearer)

# ----- AGENTS AUTONOMES (services/agents-autonomous) -----
INFERENCE_BACKEND=ollama        # ollama (tier tpe) | vllm (tier pme/+)
CHECKPOINTER_MODE=postgres      # disabled | memory | postgres
LLM_TIMEOUT_SECONDS=90
LLM_TEMPERATURE=0.2
ENABLE_OUTLINES=false           # true uniquement avec vLLM (guided_json)

# ----- VLLM (services/inference-vllm — actif uniquement si tier pme/+) -----
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEM_UTIL=0.55
HUGGING_FACE_HUB_TOKEN=         # uniquement si modèle gated

# ----- HOST URLS (network_mode: host) — fallback aibox-app -----
AGENTS_BASE_URL=http://127.0.0.1:8085
MEM0_BASE_URL=http://127.0.0.1:8087
PENNYLANE_TOOL_URL=http://127.0.0.1:8090
FEC_TOOL_URL=http://127.0.0.1:8091

# ----- N8N OWNER PASSWORD (auto-généré, NE PAS modifier) -----
# n8n exige password fort (1 maj + 1 chiffre). gen_strong_pass dans install.sh.
N8N_PASSWORD=

# ----- FEC_TOOL_API_KEY / PENNYLANE_TOOL_API_KEY / GLPI_TOOL_API_KEY etc. -----
# auto-générés par install.sh (gen_secret 48). Ne pas modifier.
FEC_TOOL_API_KEY=
PENNYLANE_TOOL_API_KEY=
GLPI_TOOL_API_KEY=
ODOO_TOOL_API_KEY=
TEXT2SQL_TOOL_API_KEY=

# ----- ACCÈS DISTANT — domaine public + Cloudflare Tunnel -----
# Quand la box est exposée via Cloudflare Tunnel (recommandé pour TPE),
# AIBOX_PUBLIC_DOMAIN définit le domaine racine. Les sous-domaines de
# services sont dérivés automatiquement (cf. SERVICE_SUBDOMAIN dans le
# code SSO et tools/setup-cloudflare-tunnel-hostnames.sh) :
#   <AIBOX_PUBLIC_DOMAIN>             → aibox-app (UI principale)
#   flows.<AIBOX_PUBLIC_DOMAIN>       → n8n
#   agents.<AIBOX_PUBLIC_DOMAIN>      → Dify console
#   auth.<AIBOX_PUBLIC_DOMAIN>        → Authentik
#   admin.<AIBOX_PUBLIC_DOMAIN>       → Portainer
#   metrics.<AIBOX_PUBLIC_DOMAIN>     → Grafana
# Laisser vide en mode LAN-only (mDNS aibox.local).
AIBOX_PUBLIC_DOMAIN=

# Credentials Cloudflare API pour le script de provisioning des hostnames.
# Voir tools/setup-cloudflare-tunnel-hostnames.sh pour le mode d'emploi.
# Le token doit avoir les scopes `Cloudflare Tunnel:Edit` + `Zone:DNS:Edit`.
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_TUNNEL_ID=
CF_ZONE_ID=

# ----- SSO PUBLIC URLS (overrides fins, optionnels) -----
# Permettent d'écraser ponctuellement le calcul fait par AIBOX_PUBLIC_DOMAIN
# (ex: si tu veux exposer uniquement n8n via un domaine perso).
DIFY_PUBLIC_URL=
N8N_PUBLIC_URL=
PORTAINER_PUBLIC_URL=
GRAFANA_PUBLIC_URL=

# ----- SERVICES (versions épinglées pour reproductibilité) -----
OLLAMA_VERSION=latest
OPEN_WEBUI_VERSION=main
DIFY_VERSION=1.10.1
AUTHENTIK_VERSION=2025.10.0
QDRANT_VERSION=v1.13.4
N8N_VERSION=latest

# ----- RÉSEAU DOCKER -----
NETWORK_NAME=aibox_net

# ----- INTÉGRATION STACK EXISTANTE (xefia) -----
# Mettre à 'true' si on intègre une stack docker déjà tournante (cas du serveur de dev xefia).
# Si false, install.sh créera tout from scratch.
INTEGRATE_EXISTING=false
EXISTING_NETWORK=stack_xefia_ollama_net

# ----- BRANDING -----
# Personnalisation de l'interface client (wizard, dashboards, emails sortants).
# Le logo est attendu en URL accessible (HTTP/HTTPS) ou data:image/png;base64,...
BRAND_NAME=AI Box
BRAND_LOGO_URL=
BRAND_PRIMARY_COLOR=#3b82f6
BRAND_ACCENT_COLOR=#10b981
BRAND_FOOTER_TEXT=

# ----- TIER PRICING (active/désactive des features) -----
# tpe        → connecteurs limités (1 source RAG + 1 messagerie max)
# pme        → tous connecteurs, 50 users max
# pme-plus   → illimité + multi-tenant
PRICING_TIER=tpe

# =============================================================================
# Services v2 OSS-inspired (2026-05-05 — cf tools/research/00_SYNTHESE.md)
# =============================================================================

# ----- SCHEDULER (P1 #6 — services/scheduler/) -----
# Sidecar qui exécute les tâches programmées par le Concierge (résumé Outlook
# matinal, alertes impayés hebdo, healthcheck auto, etc.).
# Anti-spam : MAX_JOBS_PER_USER limite le nombre de jobs actifs par user.
MAX_JOBS_PER_USER=20
# AIBOX_APP_URL : où le scheduler poste quand un job se déclenche (action_type
# agent_message ou tool_call). En host network mode → host.docker.internal:3100.
AIBOX_APP_URL=http://host.docker.internal:3100
# Timezone pour l'interprétation des cron (par défaut Europe/Paris).
TZ=Europe/Paris

# ----- SANDBOX (P0 #1 — services/sandbox/) -----
# Sidecar qui exécute du code bash/python en isolation gVisor (D1 décision).
# bash_exec côté Concierge appelle ce sandbox via SANDBOX_URL.
# Pré-requis runtime gVisor — voir services/sandbox/README.md pour POC S0.4.
SANDBOX_URL=http://aibox-sandbox:8000
# Runtime Docker du container (gVisor par défaut, runc en fallback dégradé).
SANDBOX_RUNTIME=runsc
# Network=none par défaut. Override "true" UNIQUEMENT si un workflow nécessite
# l'accès réseau (rare — préférer un tool dédié).
SANDBOX_ALLOW_NETWORK=false
# Timeouts exec (secondes). Default = défaut si caller ne précise pas.
SANDBOX_DEFAULT_TIMEOUT=30
# Cap dur, jamais dépassable par caller (anti-DoS).
SANDBOX_MAX_TIMEOUT=300

# ----- SAFETY AUDITOR (P0 #3 — lib/safety-auditor.ts) -----
# 2nd LLM qwen3:1.7b CPU qui audite les tool-calls sensitive avant exécution
# pour détecter les prompt-injections via emails/docs lus.
# Prérequis : `ollama pull qwen3:1.7b` sur xefia.
SAFETY_AUDITOR_ENABLED=true
SAFETY_AUDITOR_MODEL=qwen3:1.7b
SAFETY_AUDITOR_TIMEOUT_MS=5000
# Storage filesystem JSONL (D6 décision)
SAFETY_AUDITS_PATH=/data/safety_audits.jsonl

# ----- DELEGATE TO SPECIALIST (P0 #4 — agents-tools/delegate_to_specialist) -----
# Garde-fous délégation Concierge → specialists.
# MAX_DEPTH=2 anti-récursion (un specialist ne peut PAS re-déléguer).
AGENTS_DELEGATE_MAX_DEPTH=2
# Timeout par sub-call delegate (en ms). Au-delà → tool retourne 502 retryable.
AGENTS_DELEGATE_TIMEOUT_MS=60000

# ----- RAG HYBRID SEARCH (P2 #12 — lib/bm25-reranker.ts) -----
# Reranking BM25 sur top-N candidats Qdrant pour améliorer pertinence
# sur termes métier rares (SIRET, codes APE, références client).
RAG_HYBRID_ENABLED=true
# Coeff combinaison vector / BM25. 0.5 = équilibre, 1.0 = vector pur (skip BM25).
RAG_HYBRID_ALPHA=0.5
# Multiplier de l'over-fetch Qdrant avant rerank (limit user × OVERFETCH).
RAG_HYBRID_OVERFETCH=3

# ----- CONCIERGE APPROVAL TTL (lib/approval-gate.ts) -----
# TTL pending d'approbation (ms). Au-delà : auto-expire silencieusement.
CONCIERGE_APPROVAL_TTL_MS=300000

# ----- BACKUP OFFSITE -----
# Si renseigné, configure Duplicati avec une cible cloud chiffrée.
# Le secret n'est jamais loggé.
BACKUP_REMOTE_TYPE=         # b2 | wasabi | s3 | sftp | ""
BACKUP_REMOTE_BUCKET=
BACKUP_REMOTE_ENDPOINT=
BACKUP_REMOTE_ACCESS_KEY=
BACKUP_REMOTE_SECRET_KEY=
BACKUP_ENCRYPTION_PASSPHRASE=    # générée à l'install si vide
