# Secrets - jamais commit
.env
.env.local
*.env
!.env.example
secrets/
client_config.yaml
ACCESS.md
*.bak
.env.reset-*

# Bases SQLite locales (peuvent contenir hash de mdp)
*.db
*.sqlite
*.sqlite3

# Logs runtime du wizard / déploiement
deploy.log
reset.log

# Claude Code : on ignore tout sauf settings.json (project-level, partagé
# entre toutes les sessions — contient les hooks de garde-fou définis dans
# CLAUDE.md). settings.local.json (perso) reste ignoré.
.claude/*
!.claude/settings.json

# Volumes data Docker (montés par compose)
data/
volumes/

# Backups
backups/
*.tar.gz
*.zip
*.dump

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editeurs
.vscode/
.idea/
*.swp
*~

# Python (si on développe le portail)
__pycache__/
*.pyc
.venv/
venv/

# Node (si front portail)
node_modules/
.next/
out/
dist/
build/

# Memory (interne Claude, pas du repo produit) — exception pour services/memory/
# et pour la route Next.js /api/me/memory/ (code source à versionner).
memory/
!services/memory/
!services/memory/**
!services/app/src/app/api/me/memory/
!services/app/src/app/api/me/memory/**

# Exception : exclure pycache de services/memory
services/memory/**/__pycache__/
services/memory/**/*.pyc

# pycache des nouveaux connecteurs
services/connectors/**/__pycache__/
services/connectors/**/*.pyc
services/connectors/**/.pytest_cache/

# État local des migrations DB (par-installation, jamais commit)
tools/migrations/_state.json

# Corpus de test multimodal (récupérable depuis le serveur xefia, pas du repo)
tests/benchmark-multimodal/corpus/
