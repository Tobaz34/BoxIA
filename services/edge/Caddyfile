# =============================================================================
# AI Box — Caddy reverse proxy
# =============================================================================
# Sous-domaines exposés derrière HTTPS :
#   - {$DOMAIN}              → aibox-app (Next.js, network_mode: host)
#   - auth.{$DOMAIN}         → Authentik
#   - agents.{$DOMAIN}       → Dify (console builder)
#   - flows.{$DOMAIN}        → n8n
#   - chat.{$DOMAIN}         → Open WebUI
#   - admin.{$DOMAIN}        → Portainer
#   - status.{$DOMAIN}       → Uptime Kuma
#   - qdrant.{$DOMAIN}       → Qdrant dashboard
#
# Mode TLS :
#   - DOMAIN public + ACME_EMAIL → Let's Encrypt (acme_ca par défaut = LE prod)
#   - DOMAIN local (.local) + ACME_CA=internal → cert auto-signé Caddy local CA
# =============================================================================

{
    email {$ACME_EMAIL}
    acme_ca {$ACME_CA}
    servers {
        protocols h1 h2 h3
    }
}

# ----- Snippet : forward auth Authentik (à activer plus tard) ---------------
(authentik_proxy) {
    # forward_auth aibox-authentik-server:9000 {
    #     uri /outpost.goauthentik.io/auth/caddy
    #     copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Email
    #     trusted_proxies private_ranges
    # }
}

# ----- Healthcheck (HTTP simple) -------------------------------------------
:80 {
    @healthz path /healthz
    handle @healthz {
        respond "OK" 200
    }
    redir https://{host}{uri} permanent
}

# ----- App principale AI Box (Next.js) — landing -------------------------
# aibox-app tourne en network_mode: host → on ne peut pas l'atteindre par DNS
# Docker. On utilise host.docker.internal qui pointe vers l'host (extra_hosts
# configuré dans docker-compose.yml).
{$DOMAIN} {
    encode zstd gzip
    reverse_proxy host.docker.internal:3100 {
        flush_interval -1
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    # WebSocket (NextAuth long-poll, futur SSE chat)
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websocket {
        reverse_proxy host.docker.internal:3100
    }
}

# ----- Authentik (SSO) -----------------------------------------------------
auth.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy aibox-authentik-server:9000 {
        flush_interval -1
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# ----- Dify (agent builder console) ----------------------------------------
agents.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy aibox-dify-nginx:80 {
        flush_interval -1
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# ----- Open WebUI (chat utilisateur alternatif) ----------------------------
chat.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy open-webui:8080 {
        flush_interval -1
    }
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websocket {
        reverse_proxy open-webui:8080
    }
}

# ----- n8n (workflows) -----------------------------------------------------
flows.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy n8n:5678 {
        flush_interval -1
    }
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websocket {
        reverse_proxy n8n:5678
    }
}

# ----- Portainer (admin Docker) --------------------------------------------
admin.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy https://portainer:9443 {
        transport http {
            tls
            tls_insecure_skip_verify
        }
    }
    import authentik_proxy
}

# ----- Uptime Kuma (monitoring uptime) -------------------------------------
status.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy uptime-kuma:3001 {
        flush_interval -1
    }
}

# ----- Qdrant dashboard (RAG debug, admin only) ----------------------------
qdrant.{$DOMAIN} {
    encode zstd gzip
    reverse_proxy aibox-qdrant:6333
    import authentik_proxy
}
