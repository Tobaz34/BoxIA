{
  "version": "1.0",
  "description": "Catalogue de 30 prompts pour benchmarker l'IA locale (qwen3:14b + qwen2.5vl:7b) vs cloud (claude-sonnet-4-5). Voir tools/bench/README.md.",
  "categories": [
    {
      "id": "accounting",
      "label": "Comptabilité / chiffres"
    },
    {
      "id": "vision",
      "label": "Vision (analyse d'image)"
    },
    {
      "id": "rag",
      "label": "RAG / documents internes"
    },
    {
      "id": "files",
      "label": "Génération de fichiers"
    },
    {
      "id": "tools",
      "label": "Function calling / tools"
    },
    {
      "id": "compliance",
      "label": "Conformité FR / juridique"
    },
    {
      "id": "robustness",
      "label": "Robustesse / pièges"
    }
  ],
  "prompts": [
    {
      "id": "acc-01-tva-mixte",
      "category": "accounting",
      "agent": "accountant",
      "prompt": "Calcule la TVA récupérable sur cette facture mixte :\n- 1 ordinateur pro 1200 € HT (TVA 20%)\n- 5 repas client 50 € HT chacun (TVA 10%, déductible 0% car repas)\n- 1 abonnement logiciel SaaS 80 € HT (TVA 20%)\nDonne uniquement le total TVA récupérable, en €.",
      "scorers": [
        {"type": "numeric_present", "value": 256, "tolerance": 0.5}
      ],
      "max_tokens_response": 512,
      "timeout_s": 60
    },
    {
      "id": "acc-02-releve-bancaire",
      "category": "accounting",
      "agent": "accountant",
      "prompt": "Voici un relevé bancaire. Calcule total crédits, total débits, solde :\n2026-05-01 VIRT MARTIN credit 3500\n2026-05-02 FOURNITURES debit 147.50\n2026-05-03 URSSAF debit 2840\n2026-05-04 VIRT BERNARD credit 1200\n2026-05-05 LOYER debit 1450\n2026-05-06 EDF debit 289.30\n2026-05-07 VIRT DUPONT credit 890\n2026-05-08 TVA REMB credit 1750\n2026-05-09 ASSURANCE debit 195.40\n2026-05-10 REPAS debit 87.20\n5 lignes max.",
      "scorers": [
        {"type": "numeric_present", "value": 7340, "tolerance": 1},
        {"type": "numeric_present", "value": 5009.40, "tolerance": 0.5},
        {"type": "numeric_present", "value": 2330.60, "tolerance": 0.5},
        {"type": "no_refusal", "patterns": ["je n'ai pas les données", "je besoin"]}
      ],
      "max_tokens_response": 512,
      "timeout_s": 60
    },
    {
      "id": "acc-03-seuil-microbic",
      "category": "accounting",
      "agent": "accountant",
      "prompt": "Mon CA 2026 prévisionnel est de 175 000 € en prestations de service. Suis-je sous ou au-dessus du seuil micro-BIC pour cette activité ? Réponds en 2 phrases.",
      "scorers": [
        {"type": "regex_match", "patterns": ["77\\s?700|77700|77\\s700"]},
        {"type": "regex_match", "patterns": ["au-dessus|dépasse|supérieur"]}
      ],
      "max_tokens_response": 256,
      "timeout_s": 45
    },
    {
      "id": "acc-04-tva-renovation",
      "category": "accounting",
      "agent": "accountant",
      "prompt": "Quels sont les 3 taux de TVA applicables aux travaux de rénovation immobilière chez un particulier en 2026 ? Donne juste les taux et l'usage de chacun, format liste.",
      "scorers": [
        {"type": "regex_match", "patterns": ["20\\s?%"]},
        {"type": "regex_match", "patterns": ["10\\s?%"]},
        {"type": "regex_match", "patterns": ["5[,.]5\\s?%"]}
      ],
      "max_tokens_response": 384,
      "timeout_s": 45
    },
    {
      "id": "acc-05-devis-calculs",
      "category": "accounting",
      "agent": "accountant",
      "prompt": "Génère le tableau d'un devis avec ces 4 lignes (Désignation, Qté, PU HT, Total HT, TVA 20%, TTC) puis donne les totaux finaux :\n- Conseil 5j à 800 €\n- Hébergement 12 mois à 50 €\n- Formation 2j à 600 €\n- Audit 3j à 750 €",
      "scorers": [
        {"type": "numeric_present", "value": 8050, "tolerance": 1},
        {"type": "numeric_present", "value": 1610, "tolerance": 1},
        {"type": "numeric_present", "value": 9660, "tolerance": 1}
      ],
      "max_tokens_response": 768,
      "timeout_s": 60
    },

    {
      "id": "vis-01-facture",
      "category": "vision",
      "agent": "vision",
      "prompt": "Analyse cette facture et donne uniquement le numéro de facture, le client et le total TTC.",
