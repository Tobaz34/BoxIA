        {"type": "file_marker_present", "filename_regex": "budget.*\\.xlsx"},
        {"type": "min_file_size_kb", "value": 5}
      ],
      "max_tokens_response": 1024,
      "timeout_s": 90
    },
    {
      "id": "fil-02-cgv-docx",
      "category": "files",
      "agent": "general",
      "prompt": "Génère un document Word cgv-saas-fr.docx avec les CGV standard d'une SaaS B2B française. Au moins 8 sections (objet, prix, paiement, durée, résiliation, RGPD, propriété intellectuelle, juridiction).",
      "scorers": [
        {"type": "file_marker_present", "filename_regex": "cgv.*\\.docx"},
