      "scorers": [
        {"type": "regex_match", "patterns": ["2026-001"]},
        {"type": "regex_match", "patterns": ["ACME"]},
        {"type": "numeric_present", "value": 1500, "tolerance": 0.5}
      ],
      "max_tokens_response": 384,
      "timeout_s": 60,
      "skip_reason": "Le runner CLI n'implémente pas l'upload d'image — tester manuellement via Chrome (Ctrl+V dans le chat)"
