    {
      "id": "vis-05-handwritten-todo",
      "category": "vision",
      "agent": "vision",
      "prompt": "[À fournir : photo d'une note manuscrite] Transcris le texte exactement.",
      "image_path": null,
      "scorers": [
        {"type": "min_length", "value": 30}
      ],
      "max_tokens_response": 512,
      "timeout_s": 60,
      "skip_reason": "Image à créer (note manuscrite)"
