{
  "name": "AI Box — Sync SMB → KB Dify (horaire)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 1 }]
        }
      },
      "id": "trigger_hourly",
      "name": "Toutes les heures",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "command": "docker exec aibox-conn-rag-smb python /app/worker.py --sync-once || true"
      },
      "id": "trigger_worker",
      "name": "Trigger worker rag-smb",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [460, 300],
      "notes": "Déclenche le worker rag-smb (qui doit déjà tourner — ce node lui demande juste un sync immédiat). Si le worker n'est pas démarré côté Docker, ce node échouera silencieusement (|| true)."
    }
  ],
  "connections": {
    "Toutes les heures": { "main": [[{ "node": "Trigger worker rag-smb", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "AI Box" }, { "name": "RAG" }, { "name": "Marketplace" }]
}
