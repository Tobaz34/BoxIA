      "slug": "filesystem",
      "name": "Filesystem",
      "icon": "📁",
      "category": "official",
      "description": "Accès lecture/écriture sécurisé à un dossier local du serveur. L'IA peut lister, lire, créer, modifier des fichiers dans le dossier autorisé. Idéal pour analyser des documents internes ou générer des rapports.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "<DIRECTORY_PATH>"],
      "config_required": [
        { "key": "DIRECTORY_PATH", "label": "Dossier autorisé (ex: /data/shared)", "type": "string" }
      ],
      "official": true,
      "source_url": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
      "use_cases": ["Analyser des PDF locaux", "Générer des rapports", "Indexer des dossiers métier"]
    },
    {
      "slug": "github",
      "name": "GitHub",
      "icon": "🐙",
      "category": "dev",
      "description": "Lit/crée des issues, PRs, commits, branches sur n'importe quel repo GitHub où le token a accès. L'IA peut auditer du code, ouvrir des PRs, répondre à des issues.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<GITHUB_TOKEN>"
      },
      "config_required": [
        { "key": "GITHUB_TOKEN", "label": "Personal Access Token (scopes: repo, read:org)", "type": "secret" }
      ],
      "official": true,
      "source_url": "https://github.com/modelcontextprotocol/servers/tree/main/src/github",
      "use_cases": ["Audit de code automatisé", "Réponse aux issues", "Monitoring d'activité dev"]
